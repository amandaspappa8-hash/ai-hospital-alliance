from fastapi import FastAPI, HTTPException
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel

from app.api.clinical_route import router as clinical_route_router
from app.api.clinical_orders import router as clinical_orders_router

app = FastAPI(
    title="AI Hospital Assistant API",
    version="1.0.0"
)

app.add_middleware(
    CORSMiddleware,
    allow_origins=[
        "http://localhost:5173",
        "http://127.0.0.1:5173",
        "http://localhost:4173",
        "http://127.0.0.1:4173",
    ],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

USERS = {
    "admin": {
        "password": "admin123",
        "name": "System Admin",
        "role": "Admin",
    },
    "doctor": {
        "password": "doctor123",
        "name": "Dr. Demo",
        "role": "Doctor",
    },
    "radiology": {
        "password": "radio123",
        "name": "Radiology User",
        "role": "Radiology",
    },
}

PATIENTS = [
    {
        "id": "P-1001",
        "name": "Ahmed Ali",
        "age": 45,
        "gender": "Male",
        "phone": "+218910000001",
        "condition": "Chest Pain",
        "department": "Cardiology",
        "status": "Active",
    },
    {
        "id": "P-1002",
        "name": "Sara Omar",
        "age": 31,
        "gender": "Female",
        "phone": "+218910000002",
        "condition": "Fever",
        "department": "Emergency",
        "status": "Under Observation",
    },
    {
        "id": "P-1003",
        "name": "Mona Salem",
        "age": 62,
        "gender": "Female",
        "phone": "+218910000003",
        "condition": "Low Oxygen Saturation",
        "department": "ICU",
        "status": "Critical",
    },
]

from app.state import ORDERS



class LoginRequest(BaseModel):
    username: str
    password: str


@app.get("/")
def root():
    return {"status": "AI Hospital API running"}


@app.post("/auth/login")
def login(payload: LoginRequest):
    user = USERS.get(payload.username)
    if not user or user["password"] != payload.password:
        raise HTTPException(status_code=401, detail="Invalid username or password")

    return {
        "access_token": f"demo-token-{payload.username}",
        "token_type": "bearer",
        "user": {
            "username": payload.username,
            "name": user["name"],
            "role": user["role"],
        },
    }


@app.get("/patients")
def get_patients():
    return PATIENTS


@app.get("/patients/{patient_id}")
def get_patient(patient_id: str):
    for patient in PATIENTS:
        if patient["id"] == patient_id:
            return patient
    raise HTTPException(status_code=404, detail="Patient not found")


@app.get("/orders/{patient_id}")
def get_orders(patient_id: str):
    return ORDERS.get(patient_id, [])


app.include_router(clinical_route_router)
app.include_router(clinical_orders_router)
