import { useEffect, useMemo, useState } from "react"
import "../styles/medical-ui.css"
import { knowledgeEngine } from "../medical/knowledgeEngine"
import { apiGet, apiPost } from "@/lib/api"
import { getUser } from "@/lib/auth-storage"
import { useNavigate, useSearchParams } from "react-router-dom"
import VisitTimelineCard from "@/components/clinical/VisitTimelineCard"
import SmartOrdersCard from "@/components/clinical/SmartOrdersCard"
import DigitalSignatureCard from "@/components/clinical/DigitalSignatureCard"
import DecisionEngineCard from "@/components/clinical/DecisionEngineCard"

import { buildVisitTimeline } from "@/lib/visitTimeline"
import { buildSmartOrders } from "@/lib/smartOrders"
import { buildDigitalSignature } from "@/lib/digitalSignature"
import { runSmartDecisionEngine } from "@/lib/smartDecisionEngine"

type Patient = {
  id: string
  name: string
  age?: number
  gender?: string
  department?: string
  status?: string
  condition?: string
}

type Note = {
  id: number
  text: string
}

export default function ClinicalDecisionPage() {
  const generateClinicalSummary = () => {
  const summary =
    "Clinical Impression:\nCardiac risk suspected\n\n" +
    "Recommended Plan:\nECG + Troponin\n\n" +
    "Next Step:\nAdmit patient"

  setAiSummary(summary)
}
  const navigate = useNavigate()
  const currentUser = getUser()
  const [searchParams] = useSearchParams()
  const patientIdFromUrl = searchParams.get("patientId") ?? ""
  const [aiSummary, setAiSummary] = useState("")
  const complaintFromUrl = searchParams.get("complaint") ?? ""

  const [patients, setPatients] = useState<Patient[]>([])
  const [selectedPatientId, setSelectedPatientId] = useState(patientIdFromUrl)
  const [text, setText] = useState(
    complaintFromUrl || "chest pain, sweating, shortness of breath"
  )
  const [hr, setHr] = useState("118")
  const [sbp, setSbp] = useState("95")
  const [temp, setTemp] = useState("38.6")
  const [spo2, setSpo2] = useState("91")
  const [notes, setNotes] = useState<Note[]>([])
  const [error, setError] = useState("")
  const [sendingToNotes, setSendingToNotes] = useState(false)

  useEffect(() => {
    async function loadPatients() {
      try {
        const data = await apiGet<Patient[]>("/patients")
        const rows = Array.isArray(data) ? data : []
        setPatients(rows)

        if (patientIdFromUrl) {
          const found = rows.find((p) => p.id === patientIdFromUrl)
          if (found) {
            setSelectedPatientId(found.id)
          } else if (rows.length > 0) {
            setSelectedPatientId(rows[0].id)
          }
        } else if (rows.length > 0) {
          setSelectedPatientId(rows[0].id)
        }
      } catch (e) {
        console.error(e)
        setError("Failed to load patients")
      }
    }

    loadPatients()
  }, [patientIdFromUrl])

  useEffect(() => {
    async function loadNotes() {
      if (!selectedPatientId) return

      try {
        const data = await apiGet<Note[]>(`/notes/${selectedPatientId}`)
        const rows = Array.isArray(data) ? data : []
        setNotes(rows)

        const latestNotesText = rows
          .slice(-3)
          .map((n) => n.text)
          .filter(Boolean)
          .join(" | ")

        const baseComplaint =
          complaintFromUrl ||
          patients.find((p) => p.id === selectedPatientId)?.condition ||
          ""

        if (latestNotesText && baseComplaint) {
          setText(`${baseComplaint} | Notes: ${latestNotesText}`)
        } else if (latestNotesText && !baseComplaint) {
          setText(`Notes: ${latestNotesText}`)
        } else if (baseComplaint) {
          setText(baseComplaint)
        }
      } catch (e) {
        console.error(e)
      }
    }

    loadNotes()
  }, [selectedPatientId, complaintFromUrl, patients])

  const selectedPatient =
    patients.find((p) => p.id === selectedPatientId) ?? null
  const timelineItems = buildVisitTimeline(selected)
const smartOrders = buildSmartOrders(selected)
const digitalSignature = buildDigitalSignature("Dr Mohammed Elfallah")
const decisionResult = runSmartDecisionEngine(selected)
  const result = useMemo(
    () =>
      knowledgeEngine(text, {
        hr: Number(hr),
        sbp: Number(sbp),
        temp: Number(temp),
        spo2: Number(spo2),
      }),
    [text, hr, sbp, temp, spo2]
  )

  function getVisitDate() {
    return new Date().toLocaleString()
  }

  function buildClinicalSummary() {
    const hospitalName = "AI Hospital Alliance"
    const doctorName = currentUser?.name ?? "Attending Physician"
    const doctorRole = currentUser?.role ?? "Doctor"
    const visitDate = getVisitDate()
    const [aiSummary, setAiSummary] = useState("")

const generateClinicalSummary = () => {
  const summary =
    "Clinical Impression:\nCardiac risk suspected\n\n" +
    "Recommended Plan:\nECG + Troponin\n\n" +
    "Next Step:\nAdmit patient"

  setAiSummary(summary)
}
    return [
      hospitalName,
      "Clinical Decision Support Report",
      "----------------------------------------",
      `Doctor: ${doctorName}`,
      `Role: ${doctorRole}`,
      `Visit Date: ${visitDate}`,
      `Patient: ${selectedPatient?.name ?? "Unknown"} (${selectedPatient?.id ?? selectedPatientId})`,
      `Age: ${selectedPatient?.age ?? "N/A"} | Gender: ${selectedPatient?.gender ?? "N/A"}`,
      `Department: ${selectedPatient?.department ?? "N/A"} | Status: ${selectedPatient?.status ?? "N/A"}`,
      "",
      `Complaint: ${text}`,
      `Vitals: HR ${hr}, SBP ${sbp}, Temp ${temp}°C, SpO2 ${spo2}%`,
      "",
      `Risk Score: ${result.riskScore}/100`,
      `Severity: ${result.severity}`,
      "",
      `Clinical Impression: ${result.clinicalImpression}`,
      `Recommended Plan: ${result.recommendedPlan}`,
      `Next Step Summary: ${result.nextStepSummary}`,
      "",
      `Differential Diagnosis: ${result.diagnosisScores.map((d) => `#${d.rank} ${d.name} (${d.confidence}%)`).join(" | ")}`,
      `Routing: ${result.routing.join(", ") || "N/A"}`,
      `Labs: ${result.labs.join(", ") || "N/A"}`,
      `Medications: ${result.drugs.join(", ") || "N/A"}`,
      `Actions: ${result.actions.join(", ") || "N/A"}`,
      `Alerts: ${result.alerts.join(" | ") || "None"}`,
    ].join("\n")
  }

  function exportClinicalSummary() {
    const summary = buildClinicalSummary()
    localStorage.setItem("AI_CLINICAL_SUMMARY", summary)
    navigator.clipboard.writeText(summary).catch(() => {})
    alert("Clinical Summary exported and copied")
  }

  async function sendSummaryToNotes() {
    if (!selectedPatientId) {
      alert("No patient selected")
      return
    }

    const summary = buildClinicalSummary()
    setSendingToNotes(true)

    try {
      await apiPost(`/notes/${selectedPatientId}`, {
        text: summary,
      })
      localStorage.setItem("AI_CLINICAL_SUMMARY", summary)
      alert("Clinical Summary sent to Notes successfully")

      const refreshed = await apiGet<Note[]>(`/notes/${selectedPatientId}`)
      setNotes(Array.isArray(refreshed) ? refreshed : [])
    } catch (e) {
      console.error(e)
      alert("Failed to send summary to Notes")
    } finally {
      setSendingToNotes(false)
    }
  }

  function sendSummaryToReports() {
    const summary = buildClinicalSummary()
    localStorage.setItem(
      "AI_REPORT_DRAFT",
      JSON.stringify({
        patientId: selectedPatient?.id ?? "",
        patientName: selectedPatient?.name ?? "",
        title: `Official Clinical Summary - ${selectedPatient?.name ?? "Patient"}`,
        status: "draft",
        body: summary,
        hospitalName: "AI Hospital Alliance",
        doctorName: currentUser?.name ?? "Attending Physician",
        visitDate: getVisitDate(),
      })
    )
    alert("Clinical Summary sent to Reports draft")
    navigate("/reports")
  }

  function generatePrintablePdf() {
    const summary = buildClinicalSummary()
    const printable = window.open("", "_blank", "width=900,height=1200")
    if (!printable) {
      alert("Popup blocked")
      return
    }

    printable.document.write(`
      <html>
        <head>
          <title>Clinical Summary PDF</title>
          <style>
            body {
              font-family: Arial, sans-serif;
              margin: 40px;
              color: #111827;
              line-height: 1.7;
            }
            .header {
              border-bottom: 3px solid #0f172a;
              padding-bottom: 16px;
              margin-bottom: 24px;
            }
            .hospital {
              font-size: 28px;
              font-weight: 700;
            }
            .subtitle {
              margin-top: 6px;
              font-size: 16px;
              color: #475569;
            }
            .meta {
              margin-top: 16px;
              font-size: 14px;
            }
            pre {
              white-space: pre-wrap;
              font-family: Arial, sans-serif;
              font-size: 14px;
            }
          </style>
        </head>
        <body>
          <div class="header">
            <div class="hospital">AI Hospital Alliance</div>
            <div class="subtitle">Official Clinical Decision Report</div>
            <div class="meta">
              Doctor: ${String(currentUser?.name ?? "Attending Physician")}<br/>
              Visit Date: ${getVisitDate()}<br/>
              Patient: ${String(selectedPatient?.name ?? "Unknown")} (${String(selectedPatient?.id ?? selectedPatientId)})
            </div>
          </div>
          <pre>${summary.replace(/</g, "&lt;").replace(/>/g, "&gt;")}</pre>
        </body>
      </html>
    `)
    printable.document.close()
    printable.focus()
    printable.print()
  }

  return (
    <div>
      <h1 className="page-title">AI Clinical Decision Support</h1>
      <button onClick={generateClinicalSummary} className="btn btn-warning">
Generate Clinical Summary
</button>
      {error && (
        <div style={{ color: "#fca5a5", marginBottom: 16 }}>{error}</div>
      )}
      {aiSummary && (
  <div className="card">
    <h3>AI Clinical Summary</h3>
    <pre>{aiSummary}</pre>
  </div>
)}
      <div
        style={{
          display: "grid",
          gridTemplateColumns: "420px minmax(0,1fr)",
          gap: 20,
          alignItems: "start",
        }}
      >
        <div className="med-card">
          <div style={{ fontWeight: 700, marginBottom: 12 }}>
            Patient Context
          </div>

          <select
            value={selectedPatientId}
            onChange={(e) => setSelectedPatientId(e.target.value)}
            style={inputStyle}
          >
            {patients.map((p) => (
              <option key={p.id} value={p.id}>
                {p.name} ({p.id})
              </option>
            ))}
          </select>

          {selectedPatient && (
            <div
              style={{
                marginTop: 12,
                padding: 12,
                borderRadius: 10,
                background: "#0b1220",
                border: "1px solid #1f2937",
              }}
            >
              <div style={{ display: "grid", gap: 18, marginTop: 18 }}>
  <VisitTimelineCard items={timelineItems} />
  <SmartOrdersCard orders={smartOrders} />
  <DecisionEngineCard result={decisionResult} />
  <DigitalSignatureCard signature={digitalSignature} />
</div>
              <div style={{ fontWeight: 700 }}>{selectedPatient.name}</div>
              <div style={{ opacity: 0.75, marginTop: 6 }}>ID: {selectedPatient.id}</div>
              <div style={{ opacity: 0.75, marginTop: 6 }}>Age: {selectedPatient.age ?? "N/A"}</div>
              <div style={{ opacity: 0.75, marginTop: 6 }}>Gender: {selectedPatient.gender ?? "N/A"}</div>
              <div style={{ opacity: 0.75, marginTop: 6 }}>Department: {selectedPatient.department ?? "N/A"}</div>
              <div style={{ opacity: 0.75, marginTop: 6 }}>Status: {selectedPatient.status ?? "N/A"}</div>
              <div style={{ opacity: 0.75, marginTop: 6 }}>Condition: {selectedPatient.condition ?? "N/A"}</div>
            </div>
          )}

          {notes.length > 0 && (
            <div
              style={{
                marginTop: 12,
                padding: 12,
                borderRadius: 10,
                background: "#111827",
                border: "1px solid #374151",
              }}
            >
              <div style={{ fontWeight: 700, marginBottom: 8 }}>
                Recent Clinical Notes
              </div>
              {notes.slice(-3).map((note) => (
                <div
                  key={note.id}
                  style={{
                    padding: "8px 10px",
                    marginBottom: 8,
                    borderRadius: 8,
                    background: "#0b1220",
                    border: "1px solid #1f2937",
                    opacity: 0.9,
                  }}
                >
                  {note.text}
                </div>
              ))}
            </div>
          )}

          <div style={{ fontWeight: 700, marginTop: 18, marginBottom: 12 }}>
            Clinical Complaint Input
          </div>

          <textarea
            value={text}
            onChange={(e) => setText(e.target.value)}
            placeholder="Enter symptoms, complaint, or clinical summary..."
            style={{
              width: "100%",
              minHeight: 180,
              padding: 14,
              borderRadius: 12,
              border: "1px solid #334155",
              background: "#020617",
              color: "white",
            }}
          />

          <div
            style={{
              display: "grid",
              gridTemplateColumns: "1fr 1fr",
              gap: 12,
              marginTop: 14,
            }}
          >
            <div>
              <div style={{ marginBottom: 6, fontSize: 13 }}>HR</div>
              <input value={hr} onChange={(e) => setHr(e.target.value)} style={inputStyle} />
            </div>

            <div>
              <div style={{ marginBottom: 6, fontSize: 13 }}>SBP</div>
              <input value={sbp} onChange={(e) => setSbp(e.target.value)} style={inputStyle} />
            </div>

            <div>
              <div style={{ marginBottom: 6, fontSize: 13 }}>Temp °C</div>
              <input value={temp} onChange={(e) => setTemp(e.target.value)} style={inputStyle} />
            </div>

            <div>
              <div style={{ marginBottom: 6, fontSize: 13 }}>SpO2 %</div>
              <input value={spo2} onChange={(e) => setSpo2(e.target.value)} style={inputStyle} />
            </div>
          </div>

          <div style={{ display: "flex", gap: 10, flexWrap: "wrap", marginTop: 12 }}>
            <button
              onClick={() => {
                localStorage.setItem(
                  "AI_ORDER_DRAFT",
                  JSON.stringify({
                    ...result,
                    patientId: selectedPatient?.id ?? "",
                    patientName: selectedPatient?.name ?? "",
                    patientAge: selectedPatient?.age ?? null,
                    patientGender: selectedPatient?.gender ?? null,
                  })
                )
                alert("AI Orders Sent To Orders Page")
              }}
              style={primaryButtonStyle}
            >
              Create Medical Orders From AI
            </button>

            <button onClick={exportClinicalSummary} style={secondaryButtonStyle}>
              Export Clinical Summary
            </button>

            <button onClick={sendSummaryToNotes} style={notesButtonStyle}>
              {sendingToNotes ? "Sending..." : "Send Summary to Notes"}
            </button>

            <button onClick={sendSummaryToReports} style={reportsButtonStyle}>
              Send Summary to Reports
            </button>

            <button onClick={generatePrintablePdf} style={pdfButtonStyle}>
              Generate PDF Report
            </button>
          </div>
        </div>

        <div style={{ display: "grid", gap: 16 }}>
          <div className="med-card">
            <div style={{ fontSize: 18, fontWeight: 700, marginBottom: 10 }}>
              Clinical Impression
            </div>
            <div style={summaryTextStyle}>{result.clinicalImpression}</div>
          </div>

          <div className="med-card">
            <div style={{ fontSize: 18, fontWeight: 700, marginBottom: 10 }}>
              Recommended Plan
            </div>
            <div style={summaryTextStyle}>{result.recommendedPlan}</div>
          </div>

          <div className="med-card">
            <div style={{ fontSize: 18, fontWeight: 700, marginBottom: 10 }}>
              Next Step Summary
            </div>
            <div style={summaryTextStyle}>{result.nextStepSummary}</div>
          </div>
        </div>
      </div>
    </div>
  )
}

const inputStyle: React.CSSProperties = {
  width: "100%",
  padding: "10px 12px",
  borderRadius: 10,
  border: "1px solid #334155",
  background: "#020617",
  color: "white",
}

const summaryTextStyle: React.CSSProperties = {
  padding: "10px 12px",
  borderRadius: 10,
  background: "#0b1220",
  border: "1px solid #1f2937",
  lineHeight: 1.6,
  opacity: 0.95,
}

const primaryButtonStyle: React.CSSProperties = {
  padding: "10px 16px",
  borderRadius: 10,
  border: "1px solid #38bdf8",
  background: "#0284c7",
  color: "white",
  fontWeight: 700,
  cursor: "pointer",
}

const secondaryButtonStyle: React.CSSProperties = {
  padding: "10px 16px",
  borderRadius: 10,
  border: "1px solid #22c55e",
  background: "#166534",
  color: "white",
  fontWeight: 700,
  cursor: "pointer",
}

const notesButtonStyle: React.CSSProperties = {
  padding: "10px 16px",
  borderRadius: 10,
  border: "1px solid #a78bfa",
  background: "#7c3aed",
  color: "white",
  fontWeight: 700,
  cursor: "pointer",
}

const reportsButtonStyle: React.CSSProperties = {
  padding: "10px 16px",
  borderRadius: 10,
  border: "1px solid #f59e0b",
  background: "#b45309",
  color: "white",
  fontWeight: 700,
  cursor: "pointer",
}

const pdfButtonStyle: React.CSSProperties = {
  padding: "10px 16px",
  borderRadius: 10,
  border: "1px solid #ef4444",
  background: "#b91c1c",
  color: "white",
  fontWeight: 700,
  cursor: "pointer",
}
