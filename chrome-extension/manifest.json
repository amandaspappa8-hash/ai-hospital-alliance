{
  "manifest_version": 3,
  "name": "AI Hospital Alliance",
  "version": "1.0.0",
  "description": "Quick access to AI Hospital Alliance — Patients, Pharmacy, Radiology",
  "permissions": ["storage", "notifications", "activeTab"],
  "host_permissions": ["http://localhost:5173/*", "http://127.0.0.1:8000/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Hospital Alliance",
    "default_icon": { "48": "icons/icon48.png", "128": "icons/icon128.png" }
  },
  "background": { "service_worker": "background.js" },
  "icons": { "48": "icons/icon48.png", "128": "icons/icon128.png" }
}
